From af013d43823b8e7c10aed107d6e7c9d912ce3da2 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Sat, 7 Mar 2026 18:22:57 +0000
Subject: [PATCH] Remove dead code in variational_ffn.py, fix misleading
 docstring in blocks.py

- variational_ffn.py: Remove unused _sanitize_euclidean_gradients() and
  _compute_cholesky_robust() functions (~110 lines). These numpy-based
  utilities were superseded by the GPU gradient computation path
  (compute_vfe_gradients_gpu). Mark MockMultiAgentSystem adapter as LEGACY.
- blocks.py: Fix mu_prior parameter comment from "For variational FFN"
  to "Required for VFE_dynamic mode" (it raises ValueError if None).

https://claude.ai/code/session_01Wjg1gvRNYdq7eoJQqZ3T9H
---
 transformer/core/blocks.py          |   4 +-
 transformer/core/variational_ffn.py | 120 ++--------------------------
 2 files changed, 10 insertions(+), 114 deletions(-)

diff --git a/transformer/core/blocks.py b/transformer/core/blocks.py
index c4c63fc..aac5a3f 100644
--- a/transformer/core/blocks.py
+++ b/transformer/core/blocks.py
@@ -294,7 +294,7 @@ class GaugeTransformerBlock(nn.Module):
         phi: torch.Tensor,
         generators: torch.Tensor,
         mask: Optional[torch.Tensor] = None,
-        mu_prior: Optional[torch.Tensor] = None,  # For variational FFN
+        mu_prior: Optional[torch.Tensor] = None,  # Required for VFE_dynamic mode
         token_ids: Optional[torch.Tensor] = None,  # For PriorBank lookup
         targets: Optional[torch.Tensor] = None,   # For E-step observations
         W_out: Optional[torch.Tensor] = None,     # Output projection for discrete observations
@@ -606,7 +606,7 @@ class GaugeTransformerStack(nn.Module):
         phi: torch.Tensor,
         generators: torch.Tensor,
         mask: Optional[torch.Tensor] = None,
-        mu_prior: Optional[torch.Tensor] = None,  # For variational FFN
+        mu_prior: Optional[torch.Tensor] = None,  # Required for VFE_dynamic mode
         token_ids: Optional[torch.Tensor] = None,  # For PriorBank lookup
         return_intermediates: bool = False,
         cached_head_transports: Optional[list] = None,  # Cross-layer transport cache
diff --git a/transformer/core/variational_ffn.py b/transformer/core/variational_ffn.py
index f16ae3d..6e39783 100644
--- a/transformer/core/variational_ffn.py
