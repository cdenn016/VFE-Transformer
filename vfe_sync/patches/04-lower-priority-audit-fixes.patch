-                grad_sigma_align[:, i_start:i_end, block_start:block_end, block_start:block_end] += grad_sigma_block_weighted
+                grad_sigma_align[:, i_start:i_end, block_start:block_end, block_start:block_end] = (
+                    grad_sigma_align[:, i_start:i_end, block_start:block_end, block_start:block_end] + grad_sigma_block_weighted
